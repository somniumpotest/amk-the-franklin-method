<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Franklin Method - Promo Banner</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
        .serif {
            font-family: 'Playfair Display', serif;
        }
        .bg-navy {
            background-color: #0f172a;
        }
        .text-gold {
            color: #fbbf24;
        }
        .border-gold {
            border-color: #fbbf24;
        }
        .modal-active {
            display: flex !important;
        }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-200">
        <!-- Hero Section -->
        <div class="relative bg-navy p-8 md:p-12 text-white">
            <div class="absolute top-0 right-0 p-8 opacity-10">
                <svg width="120" height="120" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M7.127 22.562l-7.127 1.438 1.438-7.128 5.689 5.69zm1.414-1.414l11.438-11.438-5.69-5.69-11.438 11.438 5.69 5.69zm12.022-12.022l1.438-1.438-5.69-5.69-1.438 1.438 5.69 5.69zm3.437-3.437l-1.438 1.438-5.69-5.69 1.438-1.438 5.69 5.69z"/>
                </svg>
            </div>
            
            <div class="relative z-10">
                <span class="inline-block px-4 py-1 rounded-full border border-gold text-gold text-sm font-semibold mb-6 uppercase tracking-widest">
                    American Corner Event
                </span>
                <h1 class="serif text-4xl md:text-6xl mb-4 leading-tight">The Franklin Method</h1>
                <p class="text-xl md:text-2xl text-gray-300 serif italic mb-8">
                    «Стань лучшей версией себя: от привычек до признания»
                </p>
                <div class="flex flex-wrap gap-4 text-sm font-medium">
                    <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-lg">
                        <span>📅 2 недели</span>
                    </div>
                    <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-lg">
                        <span>🧠 Психология & English</span>
                    </div>
                    <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-lg">
                        <span>🎓 Для студентов и школьников</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Content Section -->
        <div class="p-8 md:p-12 grid md:grid-cols-2 gap-12">
            <!-- Week 1 -->
            <div>
                <h2 class="text-2xl font-bold mb-6 flex items-center gap-2 text-navy">
                    <span class="bg-navy text-white w-8 h-8 rounded-full flex items-center justify-center text-sm">1</span>
                    Week 1: Self-Learning
                </h2>
                <ul class="space-y-4">
                    <li class="flex gap-3">
                        <span class="text-gold mt-1">✦</span>
                        <div>
                            <p class="font-bold">The Art of Virtue</p>
                            <p class="text-gray-600 text-sm">Психология привычек и ваш личный трекер успеха.</p>
                        </div>
                    </li>
                    <li class="flex gap-3">
                        <span class="text-gold mt-1">✦</span>
                        <div>
                            <p class="font-bold">The Polymath Mindset</p>
                            <p class="text-gray-600 text-sm">Как развивать навыки в разных сферах одновременно.</p>
                        </div>
                    </li>
                    <li class="flex gap-3">
                        <span class="text-gold mt-1">✦</span>
                        <div>
                            <p class="font-bold">Active Reading & Writing</p>
                            <p class="text-gray-600 text-sm">Секретный метод Франклина для идеального английского.</p>
                        </div>
                    </li>
                </ul>
            </div>

            <!-- Week 2 -->
            <div>
                <h2 class="text-2xl font-bold mb-6 flex items-center gap-2 text-navy">
                    <span class="bg-navy text-white w-8 h-8 rounded-full flex items-center justify-center text-sm">2</span>
                    Week 2: Success & Recognition
                </h2>
                <ul class="space-y-4">
                    <li class="flex gap-3">
                        <span class="text-gold mt-1">✦</span>
                        <div>
                            <p class="font-bold">Personal Branding & Networking</p>
                            <p class="text-gray-600 text-sm">Создание сообществ и искусство самопрезентации.</p>
                        </div>
                    </li>
                    <li class="flex gap-3">
                        <span class="text-gold mt-1">✦</span>
                        <div>
                            <p class="font-bold">The Master of Persuasion</p>
                            <p class="text-gray-600 text-sm">Пишем Motivation Letter, которое убедит любого.</p>
                        </div>
                    </li>
                    <li class="flex gap-3">
                        <span class="text-gold mt-1">✦</span>
                        <div>
                            <p class="font-bold">Simulation: The Junto Club</p>
                            <p class="text-gray-600 text-sm">Финальная битва идей и презентация проектов.</p>
                        </div>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Call to Action -->
        <div class="bg-gray-50 p-8 text-center border-t border-gray-100">
            <p class="text-gray-500 mb-6 font-medium uppercase tracking-widest text-xs">Готовы изменить свой подход к учебе?</p>
            <button id="openModal" class="bg-navy text-white px-12 py-4 rounded-full font-bold text-lg hover:bg-slate-800 transition-all shadow-xl hover:shadow-navy/20 active:scale-95">
                Записаться на курс
            </button>
            <p class="mt-6 text-sm text-gray-400">Встречаемся в American Corner. Места ограничены.</p>
        </div>
    </div>

    <!-- Contact Modal -->
    <div id="contactModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-navy/60 backdrop-blur-sm p-4">
        <div class="bg-white rounded-3xl w-full max-w-md shadow-2xl transform transition-all scale-100 overflow-hidden">
            <div class="bg-navy p-6 text-white text-center relative">
                <button id="closeModal" class="absolute top-4 right-4 text-gray-400 hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
                <h3 class="serif text-2xl">Контакты для записи</h3>
            </div>
            <div class="p-8 space-y-6">
                <a href="tel:+77013879065" class="flex items-center gap-4 p-4 rounded-2xl bg-gray-50 hover:bg-gold/10 transition-colors border border-gray-100 group">
                    <div class="bg-navy text-white p-3 rounded-xl group-hover:bg-gold group-hover:text-navy transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="text-xs text-gray-400 uppercase font-semibold">Телефон</p>
                        <p class="text-lg font-bold text-navy">+7 701 387 9065</p>
                    </div>
                </a>
                
                <a href="https://www.instagram.com/american_corner_kostanay" target="_blank" class="flex items-center gap-4 p-4 rounded-2xl bg-gray-50 hover:bg-gold/10 transition-colors border border-gray-100 group">
                    <div class="bg-navy text-white p-3 rounded-xl group-hover:bg-gold group-hover:text-navy transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-width="2"></rect>
                            <path stroke-width="2" d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path>
                            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-width="2"></line>
                        </svg>
                    </div>
                    <div>
                        <p class="text-xs text-gray-400 uppercase font-semibold">Instagram</p>
                        <p class="text-lg font-bold text-navy">american_corner_kostanay</p>
                    </div>
                </a>
            </div>
            <div class="p-6 bg-gray-50 border-t border-gray-100">
                <button id="closeModalBottom" class="w-full py-3 text-sm font-semibold text-gray-500 hover:text-navy transition-colors">
                    Закрыть
                </button>
            </div>
        </div>
    </div>

    <script>
        const openBtn = document.getElementById('openModal');
        const closeBtn = document.getElementById('closeModal');
        const closeBtnBottom = document.getElementById('closeModalBottom');
        const modal = document.getElementById('contactModal');

        function toggleModal() {
            modal.classList.toggle('modal-active');
            document.body.classList.toggle('overflow-hidden');
        }

        openBtn.addEventListener('click', toggleModal);
        closeBtn.addEventListener('click', toggleModal);
        closeBtnBottom.addEventListener('click', toggleModal);

        // Close on backdrop click
        modal.addEventListener('click', (e) => {
            if (e.target === modal) toggleModal();
        });
    </script>

</body>
</html>
